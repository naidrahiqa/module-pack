#!/system/bin/sh
# Network Optimization - System Properties
# Author: Naidrahiqa

# TCP buffer sizes
net.tcp.buffersize.default=4096,87380,262144,4096,87380,262144
net.tcp.buffersize.wifi=524288,1048576,2097152,262144,524288,1048576
net.tcp.buffersize.lte=524288,1048576,2097152,262144,524288,1048576

# DNS servers
net.dns1=8.8.8.8
net.dns2=8.8.4.4

# TCP optimizations
net.ipv4.tcp_fastopen=3
net.ipv4.tcp_syncookies=1
net.ipv4.tcp_timestamps=1
net.ipv4.tcp_sack=1
