#!/sbin/sh
# KernelSU Module Installer
TMPDIR=/dev/tmp
rm -rf $TMPDIR
mkdir -p $TMPDIR
unzip -o "$3" -d $TMPDIR >&2
if [ ! -f "$TMPDIR/module.prop" ]; then
  echo "module.prop not found!"
  exit 1
fi
MODDIR=/data/adb/modules/$(grep "^id=" "$TMPDIR/module.prop" | cut -d= -f2)
rm -rf "$MODDIR"
mkdir -p "$MODDIR"
cp -rf $TMPDIR/* "$MODDIR/"
cp -rf $TMPDIR/.* "$MODDIR/" 2>/dev/null
chmod -R 755 "$MODDIR"/*.sh 2>/dev/null
chmod 644 "$MODDIR/module.prop" "$MODDIR/sepolicy.rule" 2>/dev/null
rm -rf "$MODDIR/META-INF"
rm -rf "$MODDIR/update-binary" "$MODDIR/updater-script"
echo "Module installed to $MODDIR"
echo "Reboot required."
